# Environment Variables — DuckCore AI Backend
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env — it is already in .gitignore.
#
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ─── OpenRouter API Key ───────────────────────────────────────────────────────
# HOW TO GET:
#   1. Go to https://openrouter.ai
#   2. Sign up / Log in with Google or GitHub
#   3. Click your profile → "Keys" → "Create Key"
#   4. Copy the key (starts with "sk-or-v1-...")
#   5. Paste it below
#
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ─── MongoDB URI ──────────────────────────────────────────────────────────────
# HOW TO GET (Option A — Local MongoDB):
#   1. Install MongoDB Community: https://www.mongodb.com/try/download/community
#   2. Start with: brew services start mongodb-community
#   3. Use the URI below as-is
#
# HOW TO GET (Option B — MongoDB Atlas Cloud, free tier):
#   1. Go to https://www.mongodb.com/cloud/atlas
#   2. Create a free cluster (M0 — Free)
#   3. Click "Connect" → "Drivers" → copy the connection string
#   4. Replace <username>, <password>, and <dbname> in the URI
#      Example: mongodb+srv://admin:mypassword@cluster0.xxxxx.mongodb.net/duckcore
#
MONGO_URI=mongodb://127.0.0.1:27017/duckcore

# ─── Server Port ──────────────────────────────────────────────────────────────
# The port the Express backend will listen on.
# Default: 5000   (frontend is configured to call http://localhost:5000)
#
PORT=5000
