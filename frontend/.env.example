# Environment Variables — DuckCore AI Frontend
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# Vite requires VITE_ prefix for variables to be accessible via import.meta.env
# ──────────────────────────────────────────────────────────────────────────────

# ─── API Base URL ─────────────────────────────────────────────────────────────
# The address of your DuckCore backend.
# Default for development: http://localhost:5000
#
VITE_API_BASE_URL=http://localhost:5000
